{
  "name": "capital-death-taxes",
  "version": "1.0.0",
  "description": "Deterministic card game simulator for Borrow & Die",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test":    "node test/smoke.js",
    "preview": "node dashboard/server.js",
    "scenario-default": "node cli/run.js --scenario default-4p --runs 100",
    "scenario-random": "node cli/run.js --scenario all-random --runs 100",
    "scenario-income": "node cli/run.js --scenario income-trap-test --runs 100",
    "step-default": "node cli/run.js --scenario default-4p --runs 1 --step",
    "clean": "rm output/runs/*"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "commander": "^12.0.0",
    "seedrandom": "^3.0.5"
  }
}
